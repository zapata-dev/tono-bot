# =============================================================================
# Tono-Bot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# --- Required ---
EVOLUTION_API_URL=              # Evolution API endpoint (e.g. https://evo.example.com)
EVOLUTION_API_KEY=              # Evolution API authentication key
OPENAI_API_KEY=                 # OpenAI API key (fallback LLM + Whisper transcription)
GEMINI_API_KEY=                 # Google Gemini API key (primary LLM)

# --- LLM Configuration ---
LLM_PRIMARY=gemini                          # Primary LLM provider: "gemini" or "openai"
OPENAI_MODEL=gemini-2.5-flash-lite          # Primary model name (used with Gemini)
OPENAI_FALLBACK_MODEL=gpt-4o-mini           # Fallback model name (used with OpenAI)

# --- WhatsApp & Bot ---
EVO_INSTANCE=Maximo Cervantes 2             # WhatsApp instance name in Evolution API
OWNER_PHONE=                                # Owner's phone for lead alerts (e.g. 5215512345678)
MESSAGE_ACCUMULATION_SECONDS=8.0            # Debounce window (seconds) for rapid messages

# --- Data Sources ---
SHEET_CSV_URL=                              # Google Sheets public CSV export URL for inventory
INVENTORY_REFRESH_SECONDS=300               # Inventory cache TTL in seconds (default: 5 min)
SQLITE_PATH=/app/tono-bot/db/memory.db      # SQLite database file path

# --- Handoff (Human Detection) ---
TEAM_NUMBERS=                               # Comma-separated phone numbers of human agents
AUTO_REACTIVATE_MINUTES=60                  # Minutes bot stays silent after human handoff
HUMAN_DETECTION_WINDOW_SECONDS=3            # Time window to detect human-typed messages

# --- Logging ---
LOG_WEBHOOK_PAYLOAD=true                    # Enable/disable webhook payload logging
LOG_WEBHOOK_PAYLOAD_MAX_CHARS=6000          # Truncate webhook log payload at N characters

# --- Monday.com CRM ---
MONDAY_API_KEY=                             # Monday.com API key
MONDAY_BOARD_ID=                            # Board ID (e.g. 18396811838)
MONDAY_DEDUPE_COLUMN_ID=                    # Dedup text column (e.g. text_mkzw7xjz)
MONDAY_LAST_MSG_ID_COLUMN_ID=              # Last message ID column (e.g. text_mkzwndf)
MONDAY_PHONE_COLUMN_ID=                     # Phone column (e.g. phone_mkzwh34a)
MONDAY_STAGE_COLUMN_ID=                     # Funnel stage STATUS column (e.g. status)
MONDAY_VEHICLE_COLUMN_ID=                   # Vehicle dropdown column (e.g. dropdown_mm0gq48r)
MONDAY_PAYMENT_COLUMN_ID=                   # Payment status column (e.g. color_mm0gbjea)
MONDAY_APPOINTMENT_COLUMN_ID=              # Appointment date column (e.g. date_mm0grgky)
MONDAY_APPOINTMENT_TIME_COLUMN_ID=         # Appointment hour column (e.g. hour_mm0hfk47)
MONDAY_CMV_COLUMN_ID=                       # CMV checkbox column (e.g. boolean_mm0g2zf3)
MONDAY_SOURCE_COLUMN_ID=                    # Lead source STATUS column (e.g. color_mm0wb2gm)
MONDAY_CHANNEL_COLUMN_ID=                   # Channel STATUS column (e.g. color_mm0wf5zn)
MONDAY_SOURCE_TYPE_COLUMN_ID=              # Source type STATUS column (e.g. color_mm0w1mtn)
MONDAY_AD_ID_COLUMN_ID=                     # Ad ID text column (e.g. text_mm0wcdmz)
MONDAY_CTWA_CLID_COLUMN_ID=               # CTWA Click ID text column (e.g. text_mm0wwwg1)
MONDAY_CAMPAIGN_NAME_COLUMN_ID=            # Campaign Name text column (e.g. text_mm0w77pn)
MONDAY_ADSET_NAME_COLUMN_ID=              # Ad Set Name text column (e.g. text_mm0wtebg)
MONDAY_AD_NAME_COLUMN_ID=                  # Ad Name text column (e.g. text_mm0wtpwb)
